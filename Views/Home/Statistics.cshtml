@model StatisticsViewModel
@{
    ViewData["Title"] = "Statistics";
}

<div class="page-title mb-1">Statistics</div>
<div class="page-sub mb-4">Last 30 days &middot; @Model.TotalHabits active habits</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-num" style="color:#6366f1;">@Model.CompletionRate%</div>
            <div class="stat-label">Completion Rate</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-num" style="color:#ef4444;">@Model.BestStreak</div>
            <div class="stat-label">Best Streak</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-num" style="color:#22c55e;">@Model.TotalCompletions</div>
            <div class="stat-label">Total Completions</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-num" style="color:#f59e0b;">@Model.CurrentStreak</div>
            <div class="stat-label">Current Streak</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-8">
        <div class="card p-4">
            <h6 class="fw-semibold mb-3" style="color:#374151;">Last 7 days</h6>
            <div style="position:relative;height:180px;">
                <canvas id="barChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4">
            <h6 class="fw-semibold mb-3" style="color:#374151;">Today</h6>
            <div style="position:relative;width:120px;height:120px;margin:0 auto 12px;">
                <canvas id="donutChart"></canvas>
                <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                    <span class="fw-semibold" style="font-size:1.3rem;color:#111827;">@Model.CompletedToday/@Model.TotalHabits</span>
                    <span class="text-muted" style="font-size:.7rem;">done</span>
                </div>
            </div>
            <div class="d-flex flex-column gap-1">
                <div class="d-flex align-items-center gap-2 small text-muted">
                    <span style="width:10px;height:10px;border-radius:50%;background:#6366f1;display:inline-block;"></span>
                    Completed (@Model.CompletedToday)
                </div>
                <div class="d-flex align-items-center gap-2 small text-muted">
                    <span style="width:10px;height:10px;border-radius:50%;background:#e5e7eb;display:inline-block;"></span>
                    Pending (@(Model.TotalHabits - Model.CompletedToday))
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card p-4 mb-3">
    <h6 class="fw-semibold mb-3" style="color:#374151;">30-day activity heatmap</h6>
    <div class="heat-grid mb-2">
        @foreach (var val in Model.HeatmapData)
        {
            var level = val == 0 ? "" : val == 1 ? "l1" : val == 2 ? "l2" : val <= 3 ? "l3" : "l4";
            <div class="heat-cell @level" title="@val completed"></div>
        }
    </div>
    <div class="d-flex align-items-center gap-2 mt-1" style="font-size:.75rem;color:#9ca3af;">
        <span>Less</span>
        <div style="width:12px;height:12px;border-radius:2px;background:#f1f0ff;"></div>
        <div style="width:12px;height:12px;border-radius:2px;background:#c7d2fe;"></div>
        <div style="width:12px;height:12px;border-radius:2px;background:#818cf8;"></div>
        <div style="width:12px;height:12px;border-radius:2px;background:#6366f1;"></div>
        <div style="width:12px;height:12px;border-radius:2px;background:#4338ca;"></div>
        <span>More</span>
    </div>
</div>

<div class="card p-4">
    <h6 class="fw-semibold mb-3" style="color:#374151;">Per-habit completion (last 30 days)</h6>
    @if (!Model.HabitStats.Any())
    {
        <p class="text-muted small">No habits to show yet.</p>
    }
    else
    {
        @foreach (var h in Model.HabitStats)
        {
            <div class="d-flex align-items-center gap-3 mb-3">
                <div style="width:130px;font-size:.85rem;color:#374151;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                    @h.Name
                </div>
                <div class="progress flex-grow-1" style="height:7px;">
                    <div class="progress-bar progress-bar-custom" style="width:@h.CompletionPct%;"></div>
                </div>
                <div style="width:36px;font-size:.8rem;color:#9ca3af;text-align:right;">@h.CompletionPct%</div>
                <div class="streak-fire" style="width:50px;font-size:.8rem;">
                    <i class="bi bi-fire"></i> @h.CurrentStreak d
                </div>
            </div>
        }
    }
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
    var labels = [@Html.Raw(string.Join(",", Model.Last7DaysLabels.Select(l => $"'{l}'")))];
    var data   = [@string.Join(",", Model.Last7DaysCounts)];

    new Chart(document.getElementById('barChart'), {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                data: data,
                backgroundColor: '#818cf8',
                borderRadius: 6,
                borderSkipped: false,
                hoverBackgroundColor: '#6366f1'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#9ca3af' } },
                y: { grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { font: { size: 11 }, color: '#9ca3af', stepSize: 1 }, min: 0 }
            }
        }
    });

    new Chart(document.getElementById('donutChart'), {
        type: 'doughnut',
        data: {
            datasets: [{
                data: [@Model.CompletedToday, @(Model.TotalHabits - Model.CompletedToday)],
                backgroundColor: ['#6366f1', '#e5e7eb'],
                borderWidth: 0,
                hoverOffset: 0
            }]
        },
        options: {
            responsive: false,
            cutout: '72%',
            plugins: { legend: { display: false }, tooltip: { enabled: false } }
        }
    });
</script>
}
