@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center py-4">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="mb-2" style="font-size:2.5rem;color:#6366f1;">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <h4 class="fw-bold" style="color:#111827;">Create Account</h4>
            <p class="text-muted small">Start tracking your habits today — it's free!</p>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-semibold small"></label>
                <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold small"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold small"></label>
                <input asp-for="Password" class="form-control" placeholder="Min. 6 characters" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold small"></label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="bi bi-person-check me-1"></i>Create Account
            </button>
        </form>

        <hr class="my-3" />
        <p class="text-center text-muted small mb-0">
            Already have an account?
            <a asp-controller="Account" asp-action="Login" style="color:#6366f1;font-weight:500;">Login here</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
