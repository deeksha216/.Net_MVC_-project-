@model Habit
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="page-title">@Model.Name</div>
        <div class="page-sub">Created @Model.CreatedAt.ToString("MMM dd, yyyy")</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-num" style="color:#ef4444;">@Model.CurrentStreak</div>
            <div class="stat-label"><i class="bi bi-fire me-1"></i>Current Streak</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-num" style="color:#f59e0b;">@Model.LongestStreak</div>
            <div class="stat-label"><i class="bi bi-trophy me-1"></i>Best Streak</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-num" style="color:#22c55e;">@Model.TotalCompletions</div>
            <div class="stat-label">Total Done</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-num" style="color:#6366f1; font-size:1.2rem;">@Model.Frequency</div>
            <div class="stat-label">Frequency</div>
        </div>
    </div>
</div>

<div class="card p-4 mb-3">
    <h6 class="fw-semibold mb-3">Details</h6>
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p class="text-muted">@Model.Description</p>
    }
    <div class="mt-2">
        @if (Model.CompletedToday)
        {
            <span class="badge-done fs-6"><i class="bi bi-check-circle-fill me-1"></i>Completed today!</span>
        }
        else
        {
            <span class="badge-pending fs-6"><i class="bi bi-clock me-1"></i>Not done today yet</span>
        }
    </div>
</div>

<div class="card p-4">
    <h6 class="fw-semibold mb-3">Recent Completions</h6>
    @if (!Model.Logs.Any())
    {
        <p class="text-muted small">No completions yet. Start today!</p>
    }
    else
    {
        <ul class="list-unstyled mb-0">
            @foreach (var log in Model.Logs.OrderByDescending(l => l.CompletedDate).Take(10))
            {
                <li class="d-flex align-items-center py-2 border-bottom">
                    <i class="bi bi-check-circle-fill me-2" style="color:#22c55e;"></i>
                    <span class="small">@log.CompletedDate.ToString("dddd, MMMM dd yyyy")</span>
                </li>
            }
        </ul>
    }
</div>
