@model HabitFormViewModel
@{
    ViewData["Title"] = "New Habit";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="auth-card">
            <h5 class="fw-semibold mb-1" style="color:#111827;">
                <i class="bi bi-plus-circle me-2" style="color:#6366f1;"></i>Create New Habit
            </h5>
            <p class="text-muted small mb-4">What habit do you want to build?</p>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold small"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Morning Run, Read 20 pages..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold small"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Describe your habit goal (optional)..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Frequency" class="form-label fw-semibold small"></label>
                    <select asp-for="Frequency" class="form-select">
                        <option value="Daily">Daily</option>
                        <option value="Weekly">Weekly</option>
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="bi bi-check-lg me-1"></i>Create Habit
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
